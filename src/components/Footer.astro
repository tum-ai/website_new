---
/**
 * Footer.astro
 * Static footer component - no client-side JavaScript needed
 */
---

<footer
  class="relative overflow-hidden border-t border-white/10 bg-gradient-to-br from-purple-950 to-purple-900"
>
  <div
    class="bg-grid-white/[0.02] absolute inset-0 [mask-image:radial-gradient(white,transparent_85%)]"
  >
  </div>

  <section class="relative">
    <div class="container mx-auto px-8 py-8 md:px-16">
      <div class="flex flex-col gap-12 sm:flex-row sm:justify-between">
        <div>
          <a href="/">
            <img
              src="/assets/logo_new_white_standard.png"
              class="flex text-2xl transition-all duration-300 hover:opacity-90"
              alt="TUM.ai Logo"
              width="128"
              height="32"
            />
          </a>
        </div>
        <div
          class="grid grid-cols-2 gap-8 sm:grid-cols-3 sm:gap-x-12 md:gap-x-8"
        >
          <div class="col-span-1">
            <p
              class="mb-3 text-xs font-medium tracking-wider text-white/50 uppercase"
            >
              Connect
            </p>
            <ul class="space-y-2">
              <li>
                <a
                  href="https://de.linkedin.com/company/tum-ai"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  aria-label="LinkedIn"
                >
                  LinkedIn
                </a>
              </li>
              <li>
                <a
                  href="https://www.instagram.com/tum.ai_official/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  aria-label="Instagram"
                >
                  Instagram
                </a>
              </li>
              <li>
                <a
                  href="https://join.slack.com/t/tumaipublic/shared_invite/zt-10kg0t1f9-JLRXDxY_d_vprKWgab0cVw"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  aria-label="Slack"
                >
                  Slack
                </a>
              </li>
              <li>
                <a
                  href="mailto:contact@tum-ai.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  aria-label="Email"
                >
                  Email
                </a>
              </li>
            </ul>
          </div>
          <div class="col-span-1">
            <p
              class="mb-3 text-xs font-medium tracking-wider text-white/50 uppercase"
            >
              Legal
            </p>
            <ul class="space-y-2">
              <li>
                <a
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  href="/imprint"
                >
                  Imprint
                </a>
              </li>
              <li>
                <a
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  href="/data-privacy"
                >
                  Data Privacy
                </a>
              </li>
              <li>
                <a
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  href="/disclaimer"
                >
                  Disclaimer
                </a>
              </li>
            </ul>
          </div>
          <div class="col-span-1">
            <p
              class="mb-3 text-xs font-medium tracking-wider text-white/50 uppercase"
            >
              Contribute
            </p>
            <ul class="space-y-2">
              <li>
                <a
                  class="text-sm text-white/80 transition-colors duration-300 hover:text-purple-300"
                  href="https://github.com/tum-ai/"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  GitHub
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
      <div
        class="mt-12 flex flex-col items-center justify-between border-t border-white/10 pt-8 sm:flex-row"
      >
        <p class="text-sm text-white/40">
          TUM.ai - Student Initiative at Technical University of Munich
        </p>
      </div>
    </div>
  </section>
</footer>
