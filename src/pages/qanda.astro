---
import MainLayout from "../layouts/MainLayout.astro";
import FAQ from "@/components/ui/FAQ";
import { faqs } from "@/data/qanda";
---

<MainLayout title="Q&A" description="Find answers to common questions about TUM.ai.">
  <main>
    <div class="flex flex-col min-h-screen">
      <div class="relative bg-gradient-to-br from-blue-900 to-purple-900 py-32 text-white">
        <div class="container mx-auto max-w-4xl px-4 text-center">
          <h1 class="text-5xl font-bold md:text-6xl">
            Frequently Asked <span class="text-purple-400">Questions</span>
          </h1>
          <p class="mt-4 text-lg text-gray-300">
            Find answers to common questions about TUM.ai.
          </p>
        </div>
      </div>
      <FAQ faq={faqs} client:load />
    </div>
  </main>
</MainLayout>
