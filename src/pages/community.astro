---
import MainLayout from "../layouts/MainLayout.astro";
import MemberStories from "@/components/apply/MemberStories";
import { JourneySection } from "@/components/community/JourneySection";
import { stories } from "@/data/apply/applyData";
import { departments } from "@/data/community";
import DepartmentsSection from "@/components/community/DepartmentsSection";
---

<MainLayout title="Community" description="Discover the diverse teams that make TUM.ai thrive. Each department plays a crucial role in our mission to shape the future of AI.">
  <!-- Background effects -->
  <div class="pointer-events-none fixed inset-0 z-[-1] overflow-hidden">
    <div class="bg-grid-slate-100 absolute top-0 left-0 h-full w-full opacity-5 [mask-image:linear-gradient(0deg,transparent,white)]"></div>
    <div class="absolute top-48 right-10 h-[15vw] max-h-72 w-[15vw] max-w-72 rounded-full bg-purple-400 opacity-10 blur-[clamp(40px,5vw,100px)]"></div>
    <div class="absolute top-96 left-10 h-[20vw] max-h-96 w-[20vw] max-w-96 rounded-full bg-blue-300 opacity-10 blur-[clamp(50px,6vw,120px)]"></div>
    <div class="absolute right-48 bottom-48 h-[15vw] max-h-64 w-[15vw] max-w-64 rounded-full bg-indigo-400 opacity-10 blur-[clamp(30px,4vw,80px)]"></div>
  </div>

  <section class="relative overflow-hidden bg-[#18112F] text-white">
    <JourneySection client:load />
    <DepartmentsSection departments={departments} client:visible />
    <div id="memberStories">
      <MemberStories stories={stories} client:visible />
    </div>
  </section>

  <!-- Hash scroll script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const hash = window.location.hash;
      if (hash) {
        const element = document.getElementById(hash.substring(1));
        if (element) {
          setTimeout(() => {
            const headerOffset = 64;
            const elementPosition = element.offsetTop;
            const offsetPosition = elementPosition - headerOffset;
            window.scrollTo({
              top: offsetPosition,
              behavior: "smooth",
            });
          }, 100);
        }
      }
    });
  </script>
</MainLayout>
