{
  "name": "@tumai/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "dev:web": "NEXT_DIST_DIR=.next-dev next dev",
    "build": "node scripts/run-next-command.mjs build .next-prod",
    "start": "node scripts/run-next-command.mjs start .next-prod",
    "test": "node --import=tsx --test test/*.test.ts",
    "lint": "pnpm run lint:web",
    "lint:web": "biome check .",
    "lint:apply": "biome check . --write",
    "format": "biome format .",
    "verify": "pnpm lint && pnpm test && pnpm build",
    "typecheck": "NEXT_DIST_DIR=.next-typecheck next build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tailwindcss/typography": "^0.5.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.511.0",
    "next": "^16.2.9",
    "next-sanity": "^13.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanity": "^5.29.0",
    "schema-dts": "^2.0.0",
    "server-only": "^0.0.1",
    "styled-components": "^6.4.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.5.2",
    "globals": "^16.0.0",
    "groq-js": "^1.30.3",
    "react-markdown": "^10.1.0",
    "tsx": "4.22.4",
    "tw-animate-css": "^1.3.4",
    "typescript": "~5.8.3",
    "vercel": "^50.43.0"
  }
}
