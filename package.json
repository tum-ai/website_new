{
  "name": "@tumai/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "dev:web": "NEXT_DIST_DIR=.next-dev next dev",
    "build": "NEXT_DIST_DIR=.next-prod next build",
    "start": "NEXT_DIST_DIR=.next-prod next start",
    "test": "node --test test/**/*.test.ts",
    "lint": "pnpm run lint:web && pnpm --dir packages/notion-data lint",
    "lint:web": "biome check .",
    "lint:apply": "biome check . --write",
    "format": "biome format .",
    "verify": "pnpm lint && pnpm test && pnpm build",
    "typecheck": "NEXT_DIST_DIR=.next-typecheck next build",
    "typecheck:all": "pnpm typecheck && pnpm --dir packages/notion-data typecheck"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@tailwindcss/typography": "^0.5.16",
    "@tumai/notion-data": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.15.0",
    "lucide-react": "^0.511.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "schema-dts": "^1.1.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "globals": "^16.0.0",
    "react-markdown": "^10.1.0",
    "tw-animate-css": "^1.3.4",
    "typescript": "~5.8.3",
    "vercel": "^50.43.0"
  }
}
